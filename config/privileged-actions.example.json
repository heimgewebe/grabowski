{
  "schema_version": 1,
  "actions": {
    "install_system_package": {
      "enabled": false,
      "target_pattern": "[a-z0-9][a-z0-9+.-]{0,127}",
      "argv": ["/usr/bin/apt-get", "install", "--yes", "--no-install-recommends", "{target}"],
      "timeout_seconds": 600
    },
    "edit_system_service": {
      "enabled": false,
      "target_pattern": "[A-Za-z0-9_.@:-]{1,200}",
      "argv": ["/usr/bin/systemctl", "restart", "{target}"],
      "timeout_seconds": 120
    }
  }
}
