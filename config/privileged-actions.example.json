{
  "schema_version": 2,
  "actions": {
    "edit_system_service": {
      "enabled": false,
      "target_pattern": "[A-Za-z0-9_.@:-]{1,200}",
      "argv": [
        "/usr/bin/systemctl",
        "restart",
        "{target}"
      ],
      "timeout_seconds": 120
    },
    "reset_failed_systemd_unit": {
      "enabled": false,
      "target_pattern": "(?:user@[0-9]{1,10}|[A-Za-z0-9_@][A-Za-z0-9_.@:-]{0,119})\\.service",
      "argv": [
        "/usr/bin/systemctl",
        "reset-failed",
        "{target}"
      ],
      "timeout_seconds": 30
    },
    "observe_process_references": {
      "enabled": true,
      "target_pattern": "\\{.{1,49152}\\}",
      "argv": [
        "/usr/local/libexec/grabowski-process-reference-observer",
        "{target}"
      ],
      "timeout_seconds": 30
    },
    "publish_recovery_marker": {
      "enabled": true,
      "mode": "recovery-marker-publish",
      "source_path": "/home/alex/.local/state/grabowski/recovery/last-server-recovery.json",
      "destination_path": "/var/lib/grabowski/power-worker-recovery-gate.json",
      "expected_source_uid": 1000,
      "max_recovery_age_seconds": 86400,
      "configured_target": "heimberry:rest-server/grabowski-recovery-probe",
      "kill_switch_path": "/var/lib/grabowski/operator-blockade/operator-kill-switch",
      "require_root_owned_destination": true,
      "legacy_kill_switch_path": "/home/alex/.local/state/grabowski/operator-kill-switch"
    },
    "operator_power_argv": {
      "enabled": false,
      "mode": "argv-json",
      "target_pattern": "\\{.{1,49152}\\}",
      "cwd_pattern": "/[A-Za-z0-9._/@:+-]{0,999}",
      "timeout_seconds": 600,
      "max_argv": 128,
      "allow_shell": false,
      "policy_intent": "trusted-owner-high-power-admin-catalog",
      "allowed_argv_prefixes": [
        [
          "/usr/bin/systemctl",
          "is-active"
        ],
        [
          "/usr/bin/systemctl",
          "status"
        ],
        [
          "/usr/bin/systemctl",
          "reset-failed"
        ],
        [
          "/usr/bin/apt-get",
          "update"
        ],
        [
          "/usr/bin/apt-get",
          "install",
          "-y"
        ],
        [
          "/usr/bin/docker",
          "compose"
        ],
        [
          "/usr/bin/chown"
        ],
        [
          "/usr/bin/chmod"
        ],
        [
          "/usr/bin/mount"
        ],
        [
          "/usr/bin/umount"
        ]
      ],
      "gate": {
        "kill_switch_path": "/var/lib/grabowski/operator-blockade/operator-kill-switch",
        "recovery_marker_path": "/var/lib/grabowski/power-worker-recovery-gate.json",
        "max_recovery_age_seconds": 86400,
        "require_root_owned_gate_files": true,
        "configured_target": "heimberry:rest-server/grabowski-recovery-probe",
        "legacy_kill_switch_path": "/home/alex/.local/state/grabowski/operator-kill-switch"
      }
    },
    "operator_blockade_marker_lifecycle": {
      "enabled": true,
      "mode": "blockade-marker-lifecycle",
      "marker_path": "/var/lib/grabowski/operator-blockade/operator-kill-switch",
      "legacy_marker_path": "/home/alex/.local/state/grabowski/operator-kill-switch",
      "quarantine_root": "/var/lib/grabowski/operator-blockade/quarantine",
      "authority_uid": 0,
      "legacy_uid": 1000,
      "recovery_gate": {
        "recovery_marker_path": "/var/lib/grabowski/power-worker-recovery-gate.json",
        "max_recovery_age_seconds": 86400,
        "require_root_owned_gate_files": true,
        "configured_target": "heimberry:rest-server/grabowski-recovery-probe"
      },
      "allowed_peer_unit": "grabowski-operator.service",
      "allowed_peer_uid": 1000
    },
    "operator_root_task_systemd_unit": {
      "enabled": true,
      "mode": "root-task-systemd",
      "target_pattern": "\\{.{1,49152}\\}",
      "cwd_pattern": "/[A-Za-z0-9._/@:+-]{0,999}",
      "timeout_seconds": 60,
      "max_argv": 16,
      "allow_shell": false,
      "policy_intent": "recovery-gated-root-task-catalog",
      "allowed_argv_prefixes": [
        [
          "/usr/local/bin/sleep-heimserver"
        ],
        [
          "/usr/local/bin/sleep-heim-pc"
        ],
        [
          "/usr/local/bin/sleep-heimberry"
        ]
      ],
      "start_gate": {
        "kill_switch_path": "/var/lib/grabowski/operator-blockade/operator-kill-switch",
        "recovery_marker_path": "/var/lib/grabowski/power-worker-recovery-gate.json",
        "max_recovery_age_seconds": 86400,
        "require_root_owned_gate_files": true,
        "configured_target": "heimberry:rest-server/grabowski-recovery-probe",
        "legacy_kill_switch_path": "/home/alex/.local/state/grabowski/operator-kill-switch"
      }
    }
  }
}
