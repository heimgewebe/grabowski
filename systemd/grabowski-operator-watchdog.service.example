# Productive semantic watchdog: after checking the live operator process and
# listener identity, the probe starts one bounded stdio MCP subprocess from the
# exact deployed runtime and calls only grabowski_runtime_health. It never
# opens a competing session against the stateful live HTTP endpoint.
[Unit]
Description=Grabowski operator semantic watchdog
After=grabowski-operator.service
ConditionPathExists=%h/.local/libexec/grabowski/component_watchdog.py

[Service]
Type=oneshot
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/usr/bin/python3 %h/.local/libexec/grabowski/component_watchdog.py --component operator --service grabowski-operator.service --runtime-root %h/.local/share/grabowski-mcp --module grabowski_operator --host 127.0.0.1 --port 18181 --failure-threshold 3 --max-restarts 3 --restart-window 900 --backoff-base 60 --backoff-max 900
# Exit 1 (failure observed / restart deferred) is routine evidence, not a unit
# failure. Exits 2 (indeterminate), 3 (budget exhausted) and 4 (restart did not
# recover) keep marking the unit failed.
SuccessExitStatus=1
# Worst case: probe + systemctl restart + bounded recovery re-probe loop.
TimeoutStartSec=90
UMask=0077
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.local/state/grabowski
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
LockPersonality=yes
MemoryDenyWriteExecute=yes
RestrictRealtime=yes
SystemCallArchitectures=native
