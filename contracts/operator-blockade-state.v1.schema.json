{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grabowski.local/contracts/operator-blockade-state.v1.schema.json",
  "title": "Grabowski operator blockade record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "blockade_id",
    "posture",
    "scope",
    "reason",
    "trigger_class",
    "engaged_at",
    "evidence_refs",
    "provenance",
    "source",
    "disarm_policy"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "blockade_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "posture": {
      "enum": [
        "observe",
        "preflight_required",
        "mutation_freeze",
        "hard_stop"
      ]
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "trigger_class": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
    },
    "engaged_at": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64
    },
    "expires_at": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "source": {
      "enum": [
        "typed",
        "legacy_file",
        "environment"
      ]
    },
    "disarm_policy": {
      "enum": [
        "in_band",
        "external_only"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "posture": {
            "enum": [
              "mutation_freeze",
              "hard_stop"
            ]
          }
        },
        "required": [
          "posture"
        ]
      },
      "then": {
        "not": {
          "required": [
            "expires_at"
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "source": {
            "const": "environment"
          }
        },
        "required": [
          "source"
        ]
      },
      "then": {
        "properties": {
          "disarm_policy": {
            "const": "external_only"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "posture": {
            "const": "hard_stop"
          },
          "scope": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "global"
              }
            },
            "required": [
              "kind"
            ]
          }
        },
        "required": [
          "posture",
          "scope"
        ]
      },
      "then": {
        "properties": {
          "trigger_class": {
            "enum": [
              "audit_integrity_invalid",
              "audit_provenance_unknown",
              "deployment_provenance_invalid",
              "broker_identity_invalid",
              "recovery_identity_invalid",
              "external_environment_stop",
              "host_wide_damage_unknown",
              "legacy_operator_marker",
              "global_trust_unknown"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "enum": [
            "path",
            "capability",
            "task",
            "owner",
            "repo",
            "service",
            "host",
            "global"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "global"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "const": "*"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "path",
                  "repo"
                ]
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "pattern": "^/"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "enum": [
                  "capability",
                  "task",
                  "owner",
                  "service",
                  "host"
                ]
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "maxLength": 256,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/@+-]*$"
              }
            }
          }
        }
      ]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "request_id",
        "session_id",
        "task_id",
        "owner_id"
      ],
      "properties": {
        "tool": {
          "$ref": "#/$defs/provenanceString"
        },
        "request_id": {
          "$ref": "#/$defs/provenanceString"
        },
        "session_id": {
          "$ref": "#/$defs/provenanceString"
        },
        "task_id": {
          "$ref": "#/$defs/provenanceString"
        },
        "owner_id": {
          "$ref": "#/$defs/provenanceString"
        }
      }
    },
    "provenanceString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    }
  }
}
