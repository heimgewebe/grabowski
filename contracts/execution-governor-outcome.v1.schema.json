{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.dev/contracts/execution-governor-outcome.v1.schema.json",
  "title": "Grabowski execution governor shadow outcome v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "outcome_id",
    "recorded_at_unix",
    "recommendation_id",
    "operation_class",
    "risk_level",
    "recommended_route",
    "actual_route",
    "first_pass_success",
    "unchanged_retries",
    "ambiguous_mutation_outcomes",
    "tool_call_count",
    "elapsed_ms",
    "regression_signal",
    "friction_event_ids",
    "evidence_ref"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "outcome_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$"
    },
    "recorded_at_unix": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4102444800
    },
    "recommendation_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "operation_class": {
      "enum": [
        "read",
        "broad_read",
        "mutation",
        "external_mutation",
        "long_running",
        "high_impact"
      ]
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "recommended_route": {
      "$ref": "#/$defs/route"
    },
    "actual_route": {
      "$ref": "#/$defs/route"
    },
    "first_pass_success": {
      "type": "boolean"
    },
    "unchanged_retries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20
    },
    "ambiguous_mutation_outcomes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20
    },
    "tool_call_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "elapsed_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 86400000
    },
    "regression_signal": {
      "type": "boolean"
    },
    "friction_event_ids": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[0-9A-Za-z][0-9A-Za-z_.:-]{0,127}$"
      }
    },
    "evidence_ref": {
      "type": "string",
      "maxLength": 407,
      "pattern": "^(receipt|task|run|pr|artifact|event):[0-9A-Za-z][0-9A-Za-z_./:@#-]{0,399}$"
    }
  },
  "$defs": {
    "route": {
      "enum": [
        "typed_tool",
        "grip",
        "durable_task",
        "split_read",
        "isolated_mutation",
        "explicit_preflight",
        "stop_resource_conflict",
        "stop_missing_readback",
        "operator_stop",
        "state_readback",
        "manual_fallback"
      ]
    }
  }
}
