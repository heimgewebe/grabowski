{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/contracts/grabowski/local-evidence-result.v1.schema.json",
  "title": "Grabowski Local Evidence Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "status",
    "repo",
    "head",
    "branch",
    "artifacts",
    "limitations",
    "started_at",
    "finished_at"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "job_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"
    },
    "status": {"enum": ["complete", "partial", "rejected", "failed"]},
    "repo": {"type": "string", "minLength": 1},
    "head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "branch": {"type": ["string", "null"]},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "bytes": {"type": "integer", "minimum": 0}
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"}
  }
}
